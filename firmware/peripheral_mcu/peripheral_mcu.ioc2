"File: project/peripheral_mcu.cproject.yml" = """
# yaml-language-server: $schema=https://raw.githubusercontent.com/Open-CMSIS-Pack/devtools/schemas/projmgr/2.11.0/tools/projmgr/schemas/cproject.schema.json
project:
  processor:
    trustzone: off
    dsp: on
  rte:
    base-dir: $ProjectDir()$/user_modifiable
  generators:
    base-dir: generated
  output:
    base-name: $Project$
    type:
      - elf
      - bin
      - hex
  setups:
    - setup: release_GCC
      misc:
        - ASM:
            - --specs=nano.specs
            - --specs=nosys.specs
          C:
            - -Os
            - -fdata-sections
            - -ffunction-sections
            - -std=gnu11
            - -Wall
            - -fstack-usage
            - --specs=nano.specs
            - --specs=nosys.specs
            - -Werror=implicit-function-declaration
          CPP:
            - -Os
            - -fdata-sections
            - -ffunction-sections
            - -fno-cxa-atexit
            - -fno-rtti
            - -fno-exceptions
            - -std=gnu++14
            - -Wall
            - -fstack-usage
            - --specs=nano.specs
            - --specs=nosys.specs
            - -Werror=implicit-function-declaration
          for-compiler: GCC
          Link-C:
            - -Wl,-Map=$OutDir()$/$Project$.map
            - -Wl,--gc-sections
            - -Wl,--start-group -lc -lm -Wl,--end-group
            - -static
            - --specs=nano.specs
            - --specs=nosys.specs
          Link-CPP:
            - -Wl,-Map=$OutDir()$/$Project$.map
            - -Wl,--gc-sections
            - -Wl,--start-group -lc -lm -lstdc++ -lsupc++ -Wl,--end-group
            - -static
            - --specs=nano.specs
            - --specs=nosys.specs
      for-context:
        - .release_GCC
    - setup: debug_GCC
      misc:
        - ASM:
            - -g3
            - --specs=nano.specs
            - --specs=nosys.specs
          C:
            - -g3
            - -O0
            - -fdata-sections
            - -ffunction-sections
            - -std=gnu11
            - -Wall
            - -fstack-usage
            - --specs=nano.specs
            - --specs=nosys.specs
            - -Werror=implicit-function-declaration
          CPP:
            - -g3
            - -O0
            - -fdata-sections
            - -ffunction-sections
            - -fno-cxa-atexit
            - -fno-rtti
            - -fno-exceptions
            - -std=gnu++14
            - -Wall
            - -fstack-usage
            - --specs=nano.specs
            - --specs=nosys.specs
            - -Werror=implicit-function-declaration
          for-compiler: GCC
          Link-C:
            - -Wl,-Map=$OutDir()$/$Project$.map
            - -Wl,--gc-sections
            - -Wl,--start-group -lc -lm -Wl,--end-group
            - -static
            - --specs=nano.specs
            - --specs=nosys.specs
          Link-CPP:
            - -Wl,-Map=$OutDir()$/$Project$.map
            - -Wl,--gc-sections
            - -Wl,--start-group -lc -lm -lstdc++ -lsupc++ -Wl,--end-group
            - -static
            - --specs=nano.specs
            - --specs=nosys.specs
      for-context:
        - .debug_GCC
    - setup: release_AC6
      misc:
        - ASM:
            - -Oz
            - -g
          C:
            - -Oz
            - -std=gnu11
            - -fno-exceptions
            - -fno-rtti
            - -funsigned-char
            - -g
            - -Wmissing-prototypes
          CPP:
            - -Oz
            - -std=gnu++14
            - -fno-exceptions
            - -fno-rtti
            - -funsigned-char
            - -g
            - -Wmissing-prototypes
          for-compiler: AC6
          Link-C:
            - --map
            - --library_type=microlib
            - --symbols
            - --show_full_path
            - --inline
            - --any_contingency
          Link-CPP:
            - --library_type=microlib
            - --symbols
            - --map
            - --show_full_path
            - --inline
            - --any_contingency
      for-context:
        - .release_AC6
    - setup: debug_AC6
      misc:
        - ASM:
            - -g
            - -O0
          C:
            - -g
            - -O0
            - -std=gnu11
            - -fno-exceptions
            - -fno-rtti
            - -funsigned-char
            - -Wmissing-prototypes
          CPP:
            - -g
            - -O0
            - -std=gnu++14
            - -fno-exceptions
            - -fno-rtti
            - -funsigned-char
            - -Wmissing-prototypes
          for-compiler: AC6
          Link-C:
            - --map
            - --library_type=microlib
            - --symbols
            - --show_full_path
            - --inline
            - --any_contingency
          Link-CPP:
            - --library_type=microlib
            - --symbols
            - --map
            - --show_full_path
            - --inline
            - --any_contingency
      for-context:
        - .debug_AC6
    - setup: release_IAR
      misc:
        - C:
            - --debug
            - --dlib_config DLib_Config_Full.h
            - --no_wrap_diagnostics
            - --vla
            - --enable_restrict
            - -e
            - --require_prototypes
            - -Ohs
          CPP:
            - --debug
            - --dlib_config DLib_Config_Full.h
            - --no_wrap_diagnostics
            - --vla
            - --enable_restrict
            - -e
            - --require_prototypes
            - -Ohs
          for-compiler: IAR
          Link-C:
            - --skip_dynamic_initialization
            - --inline
            - --map=$Project$.$BuildType$+$TargetType$.map
      for-context:
        - .release_IAR
    - setup: debug_IAR
      misc:
        - C:
            - --debug
            - -On
            - --dlib_config DLib_Config_Full.h
            - --no_wrap_diagnostics
            - --vla
            - --enable_restrict
            - -e
            - --require_prototypes
          CPP:
            - --debug
            - -On
            - --dlib_config DLib_Config_Full.h
            - --no_wrap_diagnostics
            - --vla
            - --enable_restrict
            - -e
            - --require_prototypes
          for-compiler: IAR
          Link-C:
            - --skip_dynamic_initialization
            - --inline
            - --map=$Project$.$BuildType$+$TargetType$.map
      for-context:
        - .debug_IAR
  components:
    - component: STMicroelectronics::Application:stm32cubemx2_templates&no os@2.0.0
    - component: STMicroelectronics::CMSIS:CORE@6.2.0
    - component: STMicroelectronics::Device:Startup@2.0.0
    - component: STMicroelectronics::Device:STM32 HAL:PCD@2.0.0
    - component: STMicroelectronics::Device:STM32 HAL DRIVERS CORE:USB CORE DEF@2.0.0
    - component: STMicroelectronics::Device:STM32 HAL DRIVERS CORE:USB DRD@2.0.0
    - component: STMicroelectronics::Device:STM32 LL:UTILS@2.0.0
    - component: STMicroelectronics::Device:STM32CubeMX2 Codegen:Generated Code@2.0.0
    - component: STMicroelectronics::Device:STM32CubeMX2 Config:CORDIC@2.0.0
    - component: STMicroelectronics::Device:STM32CubeMX2 Config:CORE@2.0.0
    - component: STMicroelectronics::Device:STM32CubeMX2 Config:CORTEX DEBUG@2.0.0
    - component: STMicroelectronics::Device:STM32CubeMX2 Config:CORTEX MPU@2.0.0
    - component: STMicroelectronics::Device:STM32CubeMX2 Config:CORTEX NVIC@2.0.0
    - component: STMicroelectronics::Device:STM32CubeMX2 Config:CORTEX SCB@2.0.0
    - component: STMicroelectronics::Device:STM32CubeMX2 Config:CRS@2.0.0
    - component: STMicroelectronics::Device:STM32CubeMX2 Config:FLASH@2.0.0
    - component: STMicroelectronics::Device:STM32CubeMX2 Config:I2C@2.0.0
    - component: STMicroelectronics::Device:STM32CubeMX2 Config:ICACHE@2.0.0
    - component: STMicroelectronics::Device:STM32CubeMX2 Config:PCD@2.0.0
    - component: STMicroelectronics::Device:STM32CubeMX2 Config:RAMCFG@2.0.0
    - component: STMicroelectronics::Device:STM32CubeMX2 Config:RCC@2.0.0
    - component: STMicroelectronics::Device:STM32CubeMX2 Config:SPI@2.0.0
    - component: STMicroelectronics::Device:STM32CubeMX2 Config:System@2.0.0
    - component: STMicroelectronics::Device:STM32CubeMX2 Config:UART@2.0.0
    - component: STMicroelectronics::Device:STM32CubeMX2 Config:USART@2.0.0
    - component: STMicroelectronics::Utility:STM32CubeMX2 Config:syscalls@1.0.0
"""
